rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Default safety net (deny all by default)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- PRIMITIVE DEFINITIONS & HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- ENTITY SPECIFIC VALIDATORS ---

    function isValidVehicle(data) {
      return data.keys().hasAll(['truckNumber', 'manufacturer', 'tyresCount', 'hasLiftAxle', 'supervisorName', 'driverName', 'currentLocation', 'lastUpdated'])
        && data.keys().size() <= 20
        && data.truckNumber is string && data.truckNumber.size() > 0 && data.truckNumber.size() <= 50
        && data.manufacturer is string && (data.manufacturer == 'Tata' || data.manufacturer == 'Ashok Leyland')
        && data.tyresCount is number && (data.tyresCount == 12 || data.tyresCount == 14)
        && data.hasLiftAxle is bool
        && data.supervisorName is string && data.supervisorName.size() > 0 && data.supervisorName.size() <= 100
        && data.driverName is string && data.driverName.size() <= 100
        && data.currentLocation is string && data.currentLocation.size() <= 200
        && data.lastUpdated is string;
    }

    function isValidServiceLog(data) {
      return data.keys().hasAll(['id', 'truckNumber', 'date', 'type', 'description', 'cost', 'supervisorName'])
        && data.keys().size() <= 30
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.truckNumber is string && data.truckNumber.size() > 0 && data.truckNumber.size() <= 50
        && data.date is string
        && data.type is string && data.type.size() > 0 && data.type.size() <= 100
        && data.description is string && data.description.size() <= 1000
        && data.cost is number && data.cost >= 0
        && data.supervisorName is string && data.supervisorName.size() > 0 && data.supervisorName.size() <= 100;
    }

    function isValidTyreMaster(data) {
      return data.keys().hasAll(['serialNumber', 'brand', 'model', 'size', 'purchaseDate', 'purchaseCost', 'vendorName', 'manufacturingDate', 'expectedLifeKm', 'currentRunningKm', 'status', 'retreadCount'])
        && data.keys().size() <= 25
        && data.serialNumber is string && data.serialNumber.size() > 0 && data.serialNumber.size() <= 100
        && data.brand is string && data.brand.size() > 0 && data.brand.size() <= 100
        && data.model is string && data.model.size() > 0 && data.model.size() <= 100
        && data.size is string && data.size.size() > 0 && data.size.size() <= 50
        && data.purchaseDate is string
        && data.purchaseCost is number && data.purchaseCost >= 0
        && data.vendorName is string && data.vendorName.size() <= 150
        && data.manufacturingDate is string
        && data.expectedLifeKm is number && data.expectedLifeKm >= 0
        && data.currentRunningKm is number && data.currentRunningKm >= 0
        && data.status is string && (data.status == 'New' || data.status == 'Active' || data.status == 'Spare' || data.status == 'Removed' || data.status == 'Retread' || data.status == 'Scrap')
        && data.retreadCount is number && data.retreadCount >= 0;
    }

    function isValidTyreHistory(data) {
      return data.keys().hasAll(['id', 'serialNumber', 'truckNumber', 'positionId', 'positionName', 'installedDate', 'kmAtInstallation', 'supervisorName'])
        && data.keys().size() <= 15
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.serialNumber is string && data.serialNumber.size() > 0 && data.serialNumber.size() <= 100
        && data.truckNumber is string && data.truckNumber.size() > 0 && data.truckNumber.size() <= 50
        && data.positionId is string && data.positionId.size() > 0 && data.positionId.size() <= 50
        && data.positionName is string && data.positionName.size() > 0 && data.positionName.size() <= 100
        && data.installedDate is string
        && data.kmAtInstallation is number && data.kmAtInstallation >= 0
        && data.supervisorName is string && data.supervisorName.size() > 0 && data.supervisorName.size() <= 100;
    }

    function isValidTyreMovement(data) {
      return data.keys().hasAll(['id', 'serialNumber', 'sourceVehicle', 'destinationVehicle', 'sourcePosition', 'destinationPosition', 'date', 'supervisorName'])
        && data.keys().size() <= 15
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.serialNumber is string && data.serialNumber.size() > 0 && data.serialNumber.size() <= 100
        && data.sourceVehicle is string && data.sourceVehicle.size() > 0 && data.sourceVehicle.size() <= 100
        && data.destinationVehicle is string && data.destinationVehicle.size() > 0 && data.destinationVehicle.size() <= 100
        && data.sourcePosition is string && data.sourcePosition.size() > 0 && data.sourcePosition.size() <= 100
        && data.destinationPosition is string && data.destinationPosition.size() > 0 && data.destinationPosition.size() <= 100
        && data.date is string
        && data.supervisorName is string && data.supervisorName.size() > 0 && data.supervisorName.size() <= 100;
    }

    // Validating Inspections
    function isValidTyreInspection(data) {
      return data.keys().hasAll(['id', 'serialNumber', 'truckNumber', 'positionId', 'inspectionDate', 'supervisorName', 'pressurePsi', 'treadDepthMm', 'sidewallCondition', 'remarks'])
        && data.keys().size() <= 15
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.serialNumber is string && data.serialNumber.size() > 0 && data.serialNumber.size() <= 100
        && data.truckNumber is string && data.truckNumber.size() > 0 && data.truckNumber.size() <= 50
        && data.positionId is string && data.positionId.size() > 0 && data.positionId.size() <= 50
        && data.inspectionDate is string
        && data.supervisorName is string && data.supervisorName.size() > 0 && data.supervisorName.size() <= 100
        && data.pressurePsi is number && data.pressurePsi >= 0
        && data.treadDepthMm is number && data.treadDepthMm >= 0
        && data.sidewallCondition is string && data.sidewallCondition.size() > 0 && data.sidewallCondition.size() <= 100
        && data.remarks is string && data.remarks.size() <= 500;
    }

    function isValidTyreExpense(data) {
      return data.keys().hasAll(['id', 'serialNumber', 'expenseType', 'cost', 'date', 'vendor', 'invoiceNumber'])
        && data.keys().size() <= 15
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.serialNumber is string && data.serialNumber.size() > 0 && data.serialNumber.size() <= 100
        && data.expenseType is string && (data.expenseType == 'Purchase' || data.expenseType == 'Retread' || data.expenseType == 'Replacement')
        && data.cost is number && data.cost >= 0
        && data.date is string
        && data.vendor is string && data.vendor.size() > 0 && data.vendor.size() <= 150
        && data.invoiceNumber is string && data.invoiceNumber.size() > 0 && data.invoiceNumber.size() <= 100;
    }

    function isValidRetreadRecord(data) {
      return data.keys().hasAll(['id', 'serialNumber', 'retreadVendor', 'retreadCost', 'retreadDate', 'retreadCountBefore', 'retreadCountAfter'])
        && data.keys().size() <= 10
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.serialNumber is string && data.serialNumber.size() > 0 && data.serialNumber.size() <= 100
        && data.retreadVendor is string && data.retreadVendor.size() > 0 && data.retreadVendor.size() <= 150
        && data.retreadCost is number && data.retreadCost >= 0
        && data.retreadDate is string
        && data.retreadCountBefore is number && data.retreadCountBefore >= 0
        && data.retreadCountAfter is number && data.retreadCountAfter >= 0;
    }

    function isValidServiceSchedule(data) {
      return data.keys().hasAll(['id', 'truckNumber', 'serviceType', 'status', 'createdDate'])
        && data.keys().size() <= 10
        && data.id is string && data.id.size() > 0 && data.id.size() <= 128
        && data.truckNumber is string && data.truckNumber.size() > 0 && data.truckNumber.size() <= 50
        && data.serviceType is string && data.serviceType.size() > 0 && data.serviceType.size() <= 100
        && data.status is string && (data.status == 'Upcoming' || data.status == 'In Progress' || data.status == 'Completed')
        && data.createdDate is string;
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['vehicleNo', 'type', 'title', 'message', 'priority', 'status', 'createdAt', 'read'])
        && data.keys().size() <= 10
        && data.vehicleNo is string && data.vehicleNo.size() > 0 && data.vehicleNo.size() <= 100
        && data.type is string && data.type.size() > 0 && data.type.size() <= 100
        && data.title is string && data.title.size() > 0 && data.title.size() <= 200
        && data.message is string && data.message.size() > 0 && data.message.size() <= 1000
        && data.priority is string && (data.priority == 'low' || data.priority == 'medium' || data.priority == 'high')
        && data.status is string && data.status.size() > 0 && data.status.size() <= 50
        && data.createdAt is string
        && data.read is bool;
    }

    // --- COLLECTION MATCH RULES ---

    match /vehicles/{truckNumber} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(truckNumber) && isValidVehicle(incoming());
      allow update: if isSignedIn() && isValidId(truckNumber) && isValidVehicle(incoming());
      allow delete: if isSignedIn() && isValidId(truckNumber);
    }

    match /serviceLogs/{logId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(logId) && isValidServiceLog(incoming());
      allow update: if isSignedIn() && isValidId(logId) && isValidServiceLog(incoming());
      allow delete: if isSignedIn() && isValidId(logId);
    }

    match /tyreMasters/{serialNumber} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(serialNumber) && isValidTyreMaster(incoming());
      allow update: if isSignedIn() && isValidId(serialNumber) && isValidTyreMaster(incoming());
      allow delete: if isSignedIn() && isValidId(serialNumber);
    }

    match /tyreHistories/{historyId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(historyId) && isValidTyreHistory(incoming());
      allow update: if isSignedIn() && isValidId(historyId) && isValidTyreHistory(incoming());
      allow delete: if isSignedIn() && isValidId(historyId);
    }

    match /tyreMovements/{movementId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(movementId) && isValidTyreMovement(incoming());
      allow update: if isSignedIn() && isValidId(movementId) && isValidTyreMovement(incoming());
      allow delete: if isSignedIn() && isValidId(movementId);
    }

    match /tyreInspections/{inspectionId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(inspectionId) && isValidTyreInspection(incoming());
      allow update: if isSignedIn() && isValidId(inspectionId) && isValidTyreInspection(incoming());
      allow delete: if isSignedIn() && isValidId(inspectionId);
    }

    match /tyreExpenses/{expenseId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(expenseId) && isValidTyreExpense(incoming());
      allow update: if isSignedIn() && isValidId(expenseId) && isValidTyreExpense(incoming());
      allow delete: if isSignedIn() && isValidId(expenseId);
    }

    match /retreadRecords/{recordId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(recordId) && isValidRetreadRecord(incoming());
      allow update: if isSignedIn() && isValidId(recordId) && isValidRetreadRecord(incoming());
      allow delete: if isSignedIn() && isValidId(recordId);
    }

    match /serviceSchedules/{scheduleId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(scheduleId) && isValidServiceSchedule(incoming());
      allow update: if isSignedIn() && isValidId(scheduleId) && isValidServiceSchedule(incoming());
      allow delete: if isSignedIn() && isValidId(scheduleId);
    }

    match /notifications/{notificationId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming());
      allow update: if isSignedIn() && isValidId(notificationId) && isValidNotification(incoming());
      allow delete: if isSignedIn() && isValidId(notificationId);
    }
  }
}
